<h1>New Place</h1>

<form action="/places" method="post">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <p>
    <label for="name_input">Name</label>
    <input type="text" name="name" id="name_input">
  </p>

  <button>Save</button>
</form>

<p>
  <a href="/places">Cancel</a>
</p>