<h1><%= @place["name"] %></h1>

<% if @current_user != nil %>
  <a href="/entries/new?place_id=<%= @place["id"] %>"><button>New Entry</button></a>
<% end %>

<br><br>

<table width="100%">
  <tr>
    <% @entries.each_with_index do |entry, index| %>
      <td width="33%" valign="top">
        <h3><%= entry["title"] %></h3>
        <p><%= entry["occurred_on"] %></p>
        <img src="https://via.placeholder.com/300x200" style="width:100%">
        <p><%= entry["description"] %></p>
      </td>
      <% if (index + 1) % 3 == 0 %>
        </tr><tr>
      <% end %>
    <% end %>
  </tr>
</table>

<br>
<a href="/places">Back to All Places</a>