<h1>New Place</h1>
<% if @current_user != nil %>
  <form action="/places" method="post">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <div class="mb-3">
      <label for="name_input" class="form-label">Name</label>
      <input type="text" name="name" id="name_input" class="form-control">
    </div>
    <button class="btn btn-primary">Save</button>
    <a href="/places" class="btn btn-secondary">Cancel</a>
  </form>
<% else %>
  You must first <a href="/login">login</a> to add a place.
<% end %>