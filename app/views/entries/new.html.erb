<h1>New Post</h1>
<% if @current_user != nil %>
  <form action="/entries" method="post" enctype="multipart/form-data">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <input type="hidden" name="place_id" value="<%= params["place_id"] %>">
    <div class="mb-3">
      <label for="title_input" class="form-label">Title</label>
      <input type="text" name="title" id="title_input" class="form-control">
    </div>
    <div class="mb-3">
      <label for="description_input" class="form-label">Description</label>
      <textarea name="description" id="description_input" class="form-control" rows="5"></textarea>
    </div>
    <div class="mb-3">
      <label for="occurred_on_input" class="form-label">Occurred On</label>
      <input type="date" name="occurred_on" id="occurred_on_input" class="form-control">
    </div>
    <div class="mb-3">
      <label for="image_input" class="form-label">Image</label>
      <input type="file" name="image" id="image_input" class="form-control">
    </div>
    <button class="btn btn-primary">Save</button>
    <a href="/places/<%= params["place_id"] %>" class="btn btn-secondary">Cancel</a>
  </form>
<% else %>
  You must first <a href="/login">login</a> to create a post.
<% end %>