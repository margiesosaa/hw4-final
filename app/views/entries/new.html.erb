<h1>New Entry</h1>

<% if @current_user != nil %>
  <form action="/entries" method="post">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <input type="hidden" name="place_id" value="<%= params["place_id"] %>">

    <p>
      <label for="title_input">Title</label>
      <input type="text" name="title" id="title_input">
    </p>

    <p>
      <label for="description_input">Description</label>
      <textarea name="description" id="description_input"></textarea>
    </p>

    <p>
      <label for="occurred_on_input">Occurred On</label>
      <input type="date" name="occurred_on" id="occurred_on_input">
    </p>

    <button>Save</button>
    <a href="/places/<%= params["place_id"] %>">Cancel</a>
  </form>
<% else %>
  You must first <a href="/login">login</a> to create an entry.
<% end %>